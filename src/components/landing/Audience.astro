---
import {
  Mic2,
  Music2,
  Disc3,
  Users,
  Briefcase,
  Camera,
  ArrowRight
} from "lucide-react";

const { t } = Astro.props;

const audience = [
  {
    title: t("audience.independent.title"),
    desc: t("audience.independent.desc"),
    icon: Mic2
  },
  {
    title: t("audience.rappers.title"),
    desc: t("audience.rappers.desc"),
    icon: Music2
  },
  {
    title: t("audience.producers.title"),
    desc: t("audience.producers.desc"),
    icon: Disc3
  },
  {
    title: t("audience.bands.title"),
    desc: t("audience.bands.desc"),
    icon: Users
  },
  {
    title: t("audience.managers.title"),
    desc: t("audience.managers.desc"),
    icon: Briefcase
  },
  {
    title: t("audience.creators.title"),
    desc: t("audience.creators.desc"),
    icon: Camera
  }
];
---

<section class="py-28 bg-black">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Heading -->
    <div class="text-center max-w-3xl mx-auto mb-16">

      <p class="text-violet-400 font-medium mb-3">
        {t("audience.badge")}
      </p>

      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight text-white">
        {t("audience.title")}
      </h2>

      <p class="mt-5 text-lg text-zinc-400">
        {t("audience.desc")}
      </p>

    </div>

    <!-- Cards -->
    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">

      {audience.map((item) => {
        const Icon = item.icon;

        return (
          <div class="rounded-3xl border border-white/10 bg-white/5 p-7 hover:bg-white/10 transition group">

            <div class="w-12 h-12 rounded-2xl bg-violet-500/10 flex items-center justify-center mb-5 group-hover:scale-105 transition">
              <Icon className="w-5 h-5 text-violet-400" />
            </div>

            <h3 class="text-white text-xl font-semibold leading-tight">
              {item.title}
            </h3>

            <p class="mt-3 text-zinc-400 leading-relaxed text-sm md:text-base">
              {item.desc}
            </p>

          </div>
        );
      })}

    </div>

  </div>
</section>