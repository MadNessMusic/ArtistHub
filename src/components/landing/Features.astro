---
import {
  UserCircle2,
  Image,
  Music2,
  Disc3,
  Link2,
  Palette,
  Video,
  ShoppingBag,
  Users,
  Mail
} from "lucide-react";

const { t } = Astro.props;

const features = [
  {
    title: t("features.profile.title"),
    desc: t("features.profile.desc"),
    icon: UserCircle2
  },
  {
    title: t("features.branding.title"),
    desc: t("features.branding.desc"),
    icon: Image
  },
  {
    title: t("features.tracks.title"),
    desc: t("features.tracks.desc"),
    icon: Music2
  },
  {
    title: t("features.releases.title"),
    desc: t("features.releases.desc"),
    icon: Disc3
  },
  {
    title: t("features.links.title"),
    desc: t("features.links.desc"),
    icon: Link2
  },
  {
    title: t("features.themes.title"),
    desc: t("features.themes.desc"),
    icon: Palette
  },
  {
    title: t("features.videos.title"),
    desc: t("features.videos.desc"),
    icon: Video
  },
  {
    title: t("features.merch.title"),
    desc: t("features.merch.desc"),
    icon: ShoppingBag
  },
  {
    title: t("features.collabs.title"),
    desc: t("features.collabs.desc"),
    icon: Users
  },
  {
    title: t("features.contact.title"),
    desc: t("features.contact.desc"),
    icon: Mail
  }
];
---

<section id="features" class="py-28 bg-black">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Heading -->
    <div class="max-w-3xl mb-16">

      <p class="text-violet-400 font-medium mb-3">
        {t("features.badge")}
      </p>

      <h2 class="text-4xl md:text-5xl text-white font-semibold tracking-tight">
        {t("features.title")}
      </h2>

      <p class="mt-5 text-zinc-400 text-lg max-w-2xl">
        {t("features.desc")}
      </p>

    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 xl:grid-cols-5 gap-5">

      {features.map((item) => {
        const Icon = item.icon;

        return (
          <div class="rounded-3xl border border-white/10 bg-white/5 p-6 hover:bg-white/10 hover:border-white/15 transition group">

            <div class="w-12 h-12 rounded-2xl bg-violet-500/10 flex items-center justify-center mb-5 group-hover:scale-105 transition">
              <Icon className="w-5 h-5 text-violet-400" />
            </div>

            <h3 class="text-white text-lg font-medium leading-tight">
              {item.title}
            </h3>

            <p class="mt-3 text-zinc-400 text-sm leading-relaxed">
              {item.desc}
            </p>

          </div>
        );
      })}

    </div>

  </div>
</section>