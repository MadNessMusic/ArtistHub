---
import { Plus } from "lucide-react";

const { t } = Astro.props;

const faqs = [
  {
    q: t("faq.q1"),
    a: t("faq.a1")
  },
  {
    q: t("faq.q2"),
    a: t("faq.a2")
  },
  {
    q: t("faq.q3"),
    a: t("faq.a3")
  },
  {
    q: t("faq.q4"),
    a: t("faq.a4")
  },
  {
    q: t("faq.q5"),
    a: t("faq.a5")
  },
  {
    q: t("faq.q6"),
    a: t("faq.a6")
  }
];
---

<section id="faq" class="py-28 bg-black">
  <div class="max-w-4xl mx-auto px-6 lg:px-10">

    <div class="text-center mb-16">

      <p class="text-violet-400 font-medium mb-3">
        {t("faq.badge")}
      </p>

      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight text-white">
        {t("faq.title")}
      </h2>

      <p class="mt-5 text-lg text-zinc-400">
        {t("faq.desc")}
      </p>

    </div>

    <div class="space-y-4">

      {faqs.map((item) => (
        <details class="group rounded-3xl border border-white/10 bg-white/5 p-6">

          <summary class="list-none cursor-pointer flex items-center justify-between gap-6">

            <span class="text-white font-medium text-lg">
              {item.q}
            </span>

            <Plus className="w-5 h-5 text-zinc-500 group-open:rotate-45 transition" />

          </summary>

          <p class="mt-5 text-zinc-400 leading-relaxed">
            {item.a}
          </p>

        </details>
      ))}

    </div>

  </div>
</section>