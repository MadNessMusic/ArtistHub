---
import {
  ArrowRight,
  CheckCircle2,
  PlayCircle,
  Sparkles,
  Link2,
  Music2
} from "lucide-react";

const { t } = Astro.props;
---

<section class="relative overflow-hidden pt-38 pb-28">

  <!-- Glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-240 h-240 rounded-full bg-violet-600/15 blur-[180px]"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-2 gap-16 items-center">

    <!-- LEFT -->
    <div>

      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 text-sm text-zinc-300 mb-7">
        <Sparkles className="w-4 h-4 text-violet-400" />
        {t("hero.badge")}
      </div>

      <h1 class="text-5xl md:text-7xl xl:text-8xl font-semibold tracking-tight text-white leading-[0.95]">

        {t("hero.title1")}

        <span class="block text-transparent bg-clip-text bg-linear-to-r from-violet-400 via-fuchsia-400 to-violet-300">
          {t("hero.title2")}
        </span>

      </h1>

      <p class="mt-7 text-lg md:text-xl text-zinc-400 max-w-xl leading-relaxed">
        {t("hero.desc")}
      </p>

      <div class="mt-9 flex flex-col sm:flex-row gap-4">

        <a
          href="/auth/signup"
          class="px-7 py-4 rounded-2xl bg-white text-black font-medium hover:scale-105 transition flex items-center justify-center gap-2 shadow-xl"
        >
          {t("hero.cta1")}
          <ArrowRight className="w-4 h-4" />
        </a>

        <a
          href="#templates"
          class="px-7 py-4 rounded-2xl border border-white/10 bg-white/5 text-white hover:bg-white/10 transition flex items-center justify-center gap-2"
        >
          <PlayCircle className="w-4 h-4" />
          {t("hero.cta2")}
        </a>

      </div>

      <div class="mt-10 flex flex-wrap gap-6 text-sm text-zinc-500">

        <span class="flex items-center gap-2">
          <CheckCircle2 className="w-4 h-4 text-violet-400" />
          {t("hero.feature1")}
        </span>

        <span class="flex items-center gap-2">
          <CheckCircle2 className="w-4 h-4 text-violet-400" />
          {t("hero.feature2")}
        </span>

        <span class="flex items-center gap-2">
          <CheckCircle2 className="w-4 h-4 text-violet-400" />
          {t("hero.feature3")}
        </span>

      </div>

    </div>

    <!-- RIGHT -->
    <div class="relative flex justify-center lg:justify-end">

      <!-- Smaller Mockup -->
      <div class="w-full max-w-md rounded-4xl border border-white/10 bg-white/5 backdrop-blur-xl p-4 shadow-2xl">

        <div class="rounded-3xl overflow-hidden border border-white/10 bg-zinc-950">

          <img
            src="/images/previews/pro-plan.gif"
            alt="ArtistHub Preview"
            class="w-full h-auto object-cover"
          />

        </div>

      </div>

      <!-- Floating card top -->
      <div class="hidden md:flex absolute left-0 top-10 rounded-3xl border border-white/10 bg-black/80 backdrop-blur-xl px-4 py-3 items-center gap-3 shadow-xl">

        <div class="w-10 h-10 rounded-2xl bg-violet-500/10 flex items-center justify-center">
          <Music2 className="w-4 h-4 text-violet-400" />
        </div>

        <div>
          <p class="text-white text-sm font-medium">
            Latest Release
          </p>

          <p class="text-zinc-500 text-xs">
            Streaming ready
          </p>
        </div>

      </div>

      <!-- Floating card bottom -->
      <div class="hidden md:flex absolute right-0 bottom-10 rounded-3xl border border-white/10 bg-black/80 backdrop-blur-xl px-4 py-3 items-center gap-3 shadow-xl">

        <div class="w-10 h-10 rounded-2xl bg-violet-500/10 flex items-center justify-center">
          <Link2 className="w-4 h-4 text-violet-400" />
        </div>

        <div>
          <p class="text-white text-sm font-medium">
            Smart Links
          </p>

          <p class="text-zinc-500 text-xs">
            All platforms
          </p>
        </div>

      </div>

    </div>

  </div>

</section>