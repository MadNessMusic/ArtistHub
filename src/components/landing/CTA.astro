---
import { ArrowRight, Sparkles } from "lucide-react";

const { t } = Astro.props;
---

<section class="py-28 bg-black relative overflow-hidden">

  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-190 h-190 rounded-full bg-violet-600/15 blur-[160px]"></div>

  <div class="relative max-w-5xl mx-auto px-6 lg:px-10">

    <div class="rounded-3xl border border-white/10 bg-white/5 p-10 md:p-14 text-center">

      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 text-sm text-zinc-300 mb-6">
        <Sparkles className="w-4 h-4 text-violet-400" />
        {t("cta.badge")}
      </div>

      <h2 class="text-4xl md:text-6xl font-semibold tracking-tight text-white max-w-4xl mx-auto">
        {t("cta.title")}
      </h2>

      <p class="mt-6 text-lg text-zinc-400 max-w-2xl mx-auto">
        {t("cta.desc")}
      </p>

      <a
        href="/auth/signup"
        class="mt-8 inline-flex items-center gap-2 px-7 py-4 rounded-2xl bg-white text-black font-medium hover:scale-105 transition"
      >
        {t("cta.button")}
        <ArrowRight className="w-4 h-4" />
      </a>

    </div>

  </div>

</section>