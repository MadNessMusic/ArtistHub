---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Perfil | ArtistHub">

<section class="space-y-8">

  <!-- Header -->
  <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
    <p class="text-sm uppercase tracking-widest text-violet-300">
      Perfil
    </p>

    <h1 class="mt-3 text-4xl font-semibold">
      Edita tu perfil artístico
    </h1>

    <p class="mt-3 text-zinc-400">
      Cambia imagen, biografía y enlaces públicos.
    </p>
  </div>

  <!-- Grid -->
  <div class="grid xl:grid-cols-[1.1fr_.9fr] gap-8">

    <!-- Form -->
    <div class="rounded-3xl border border-white/10 bg-white/5 p-8">

      <form id="profileForm" class="space-y-6">

        <!-- Avatar -->
        <div>
          <label class="block text-sm text-zinc-300 mb-3">
            Fotografía
          </label>

          <div class="flex items-center gap-4">

            <img
              id="avatarPreview"
              src="https://placehold.co/120x120"
              class="w-20 h-20 rounded-3xl object-cover border border-white/10"
            />

            <button
              type="button"
              id="avatarBtn"
              class="h-12 px-5 rounded-2xl bg-white text-black font-medium"
            >
              Cambiar imagen
            </button>

            <input
              type="file"
              id="avatar"
              accept="image/*"
              class="hidden"
            />

          </div>
        </div>

        <!-- Name -->
        <div>
          <label class="block text-sm text-zinc-300 mb-2">
            Nombre artístico
          </label>

          <input
            id="artist_name"
            class="w-full h-14 rounded-2xl bg-black/40 border border-white/10 px-5 text-white"
          />
        </div>

        <!-- Username -->
        <div>
          <label class="block text-sm text-zinc-300 mb-2">
            URL pública
          </label>

          <div class="h-14 rounded-2xl bg-black/40 border border-white/10 flex items-center px-5 text-zinc-400">
            artisthub.com/
            <span id="usernameText" class="text-white ml-1"></span>
          </div>
        </div>

        <!-- Bio -->
        <div>
          <label class="block text-sm text-zinc-300 mb-2">
            Biografía
          </label>

          <textarea
            id="bio"
            rows="4"
            class="w-full rounded-2xl bg-black/40 border border-white/10 px-5 py-4 text-white resize-none"
          ></textarea>
        </div>

        <!-- Links -->
        <div>
          <label class="block text-sm text-zinc-300 mb-4">
            Enlaces
          </label>

          <div id="linksContainer" class="space-y-4"></div>
        </div>

        <!-- Save -->
        <button
          type="submit"
          class="w-full h-14 rounded-2xl bg-white text-black font-medium"
        >
          Guardar cambios
        </button>

        <p
          id="status"
          class="text-center text-sm text-zinc-400"
        ></p>

      </form>

    </div>

    <!-- Preview -->
    <div class="space-y-8">

      <div class="rounded-3xl border border-white/10 bg-white/5 p-8">

        <p class="text-sm text-zinc-400 mb-5">
          Vista previa
        </p>

        <div class="rounded-3xl bg-black/40 border border-white/10 p-6">

          <img
            id="liveAvatar"
            src="https://placehold.co/120x120"
            class="w-24 h-24 rounded-3xl object-cover"
          />

          <h3
            id="liveName"
            class="mt-5 text-2xl font-semibold"
          >
            Tu nombre artístico
          </h3>

          <p
            id="liveUrl"
            class="text-sm text-zinc-500 mt-1"
          >
            artisthub.com/username
          </p>

          <p
            id="liveBio"
            class="mt-5 text-zinc-400"
          >
            Tu bio aparecerá aquí.
          </p>

          <div
            id="liveLinks"
            class="grid gap-3 mt-6"
          ></div>

        </div>

      </div>

    </div>

  </div>

</section>

<script type="module" src="/src/scripts/profile.js"></script>

</AppLayout>